{
  "name": "web-app-workflows",
  "version": "0.1.0",
  "description": "Build your own automated AI workflows on your files, right inside ownCloud Infinite Scale.",
  "license": "Apache-2.0",
  "author": "Lukas Hirt",
  "private": true,
  "homepage": "https://github.com/LukasHirt/ocis-workflows",
  "type": "module",
  "scripts": {
    "build": "pnpm vite build",
    "build:w": "pnpm vite build --watch --mode development",
    "check:types": "vue-tsc --noEmit",
    "lint": "eslint 'src/**/*.{js,ts,vue}' --color",
    "test:unit": "NODE_OPTIONS=--unhandled-rejections=throw vitest",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@ownclouders/web-client": "^12.0.0",
    "@ownclouders/web-pkg": "^12.0.0",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/controls": "^1.1.2",
    "@vue-flow/core": "^1.42.5",
    "@vue-flow/minimap": "^1.5.0",
    "vue": "^3.4.21",
    "vue-router": "^5.0.7",
    "vue3-gettext": "^2.4.0"
  },
  "devDependencies": {
    "@ownclouders/eslint-config": "12.5.0",
    "@ownclouders/extension-sdk": "12.5.0",
    "@ownclouders/prettier-config": "0.0.1",
    "@ownclouders/tsconfig": "0.0.6",
    "@playwright/test": "^1.49.0",
    "@types/node": "22.19.19",
    "@vue/test-utils": "^2.4.6",
    "eslint": "9.39.4",
    "happy-dom": "^20.9.0",
    "prettier": "3.9.5",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3",
    "vite": "7.2.2",
    "vitest": "4.1.10",
    "vue-tsc": "3.3.7"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "design-system*"
      ]
    },
    "overrides": {
      "glob": "^10.5.0"
    }
  },
  "packageManager": "pnpm@10.34.1"
}
